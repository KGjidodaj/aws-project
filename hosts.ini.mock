[proxy]
(nginx public ip) ansible_user=ubuntu ansible_ssh_private_key_file=/route to repo/aws-project/key.pem ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[app]
(app private ip) ansible_user=ubuntu ansible_ssh_private_key_file=/route to repo/aws-project/key.pem ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyCommand="ssh -W %h:%p -q ubuntu@(nginx public ip) -i /route to repo/aws-project/key.pem -o StrictHostKeyChecking=no"'

[db]
(DB private ip) ansible_user=ubuntu ansible_ssh_private_key_file=/route to repo/aws-project/key.pem ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyCommand="ssh -W %h:%p -q ubuntu@(nginx public ip) -i /route to repo/aws-project/key.pem -o StrictHostKeyChecking=no"'
